<Window x:Class="AppGestionDeVM.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GestionVM - Descar"
        Height="450"
        Width="520"
        MinHeight="450"
        MinWidth="520"
        MaxHeight="450"
        MaxWidth="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#08111F"
        Icon="/Assets/logo.png"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#1C355C"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Background" Value="#091526"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#6A95FF"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RememberCheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D7E3FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#0B1730"/>
            <Setter Property="BorderBrush" Value="#1C355C"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#6A95FF"/>
            <Setter Property="BorderBrush" Value="#6A95FF"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Width="460"
                CornerRadius="16"
                Background="#0C1524"
                BorderBrush="#1B2A42"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Border Background="Transparent"
                            MouseLeftButtonDown="DragArea_MouseLeftButtonDown"/>

                    <Button x:Name="btnCerrar"
                            Content="X"
                            Style="{StaticResource CloseButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="btnCerrar_Click"/>
                </Grid>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                    <TextBlock Text="GestionVM - Descar"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Ingresá con tu usuario"
                               Foreground="#D7E3FF"
                               FontSize="15"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Usuario" Style="{StaticResource LabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="txtUsuario"
                                 Style="{StaticResource TextInputStyle}"/>
                    </Border>

                    <TextBlock Text="Contraseña" Style="{StaticResource LabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <PasswordBox x:Name="txtPassword"
                                     Style="{StaticResource PasswordInputStyle}"
                                     KeyDown="txtPassword_KeyDown"/>
                    </Border>
                </StackPanel>

                <CheckBox x:Name="chkRecordar"
                          Grid.Row="5"
                          Content="Recordar usuario y contraseña"
                          Style="{StaticResource RememberCheckStyle}"/>

                <StackPanel Grid.Row="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="btnCancelar"
                            Content="Cancelar"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Click="btnCancelar_Click"/>

                    <Button x:Name="btnIngresar"
                            Content="Ingresar"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="btnIngresar_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>